{
  "name": "@hakunahq/ui",
  "version": "0.8.0",
  "description": "Unified design system for the Hakuna product family",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "default": "./index.js"
    },
    "./package.json": "./package.json",
    "./icons": {
      "types": "./icons.d.ts",
      "import": "./icons.js",
      "default": "./icons.js"
    },
    "./security": {
      "types": "./security.d.ts",
      "import": "./security.js",
      "default": "./security.js"
    },
    "./tokens/colors.css": "./tokens/colors.css",
    "./tokens/base.css": "./tokens/base.css",
    "./tokens/tailwind-preset": "./tokens/tailwind-preset.js",
    "./tokens/breakpoints": "./tokens/breakpoints.js",
    "./hooks/useBreakpoint": "./hooks/useBreakpoint.js",
    "./assets/*": "./assets/*",
    "./components/*": "./components/*.jsx"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "icons.js",
    "icons.d.ts",
    "security.js",
    "security.d.ts",
    "tokens/",
    "hooks/",
    "components/",
    "assets/"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "lucide-react": ">=0.300.0"
  },
  "peerDependenciesMeta": {
    "lucide-react": {
      "optional": true
    }
  },
  "keywords": [
    "hakuna",
    "design-system",
    "react",
    "tailwind",
    "ui"
  ],
  "author": "Hakuna HQ",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MrAnde7son/hakuna-ui.git"
  },
  "homepage": "https://github.com/MrAnde7son/hakuna-ui#readme",
  "bugs": {
    "url": "https://github.com/MrAnde7son/hakuna-ui/issues"
  },
  "publishConfig": {
    "access": "public"
  }
}
